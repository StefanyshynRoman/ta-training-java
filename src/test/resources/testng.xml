<!DOCTYPE suite SYSTEM "https://testng.org/testng-1.0.dtd">
<suite name="RomanStefanyshyn" parallel="tests" thread-count="2">
    <listeners>
        <listener class-name="com.epam.training.RomanStefanyshyn.listeners.TestListener"/>
    </listeners>
    <test name="Chrome Test">
        <parameter name="browser" value="chrome"/>
        <classes>
            <class name="com.epam.training.RomanStefanyshyn.tests.CheckoutTest"/>
        </classes>
    </test>

    <test name="Firefox Test">
        <parameter name="browser" value="firefox"/>
        <classes>
            <class name="com.epam.training.RomanStefanyshyn.tests.CheckoutTest"/>
        </classes>
    </test>

</suite>